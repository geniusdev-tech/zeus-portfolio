# ── zeus-backend · environment variables ───────────────
# Copy this to .env for local dev.
# On Railway/Render: set these in the dashboard — never commit .env.

# Port (Railway/Render set this automatically)
PORT=8080

# ── Email ───────────────────────────────────────────────
# Get your free API key at https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=zeus@yourdomain.com

# ── CORS ────────────────────────────────────────────────
# Set to your frontend domain in production
# e.g. https://zeus.dev  or  https://zeus-portfolio.vercel.app
ALLOWED_ORIGIN=http://localhost:5173

# ── GitHub ──────────────────────────────────────────────
# Your GitHub username (public events feed)
GITHUB_USERNAME=your-github-username

# Optional: personal access token for higher rate limit (5000 req/h vs 60)
# Create at: https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=

# ── Project health check URLs ───────────────────────────
# Leave blank if project isn't deployed yet — will show as "unknown"
QELOX_HEALTH_URL=
PORTFOLIO_URL=https://zeus.dev

# Backend's own URL (used to self-check)
SELF_URL=https://api.zeus.dev
